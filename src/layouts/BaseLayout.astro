---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { pageTitle = 'Astro Demo' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog Collection' },
  { href: '/api/time.json', label: 'API Demo' },
  { href: '/rendering', label: 'Rendering Lab' }
];

const footerLinks = [
  { href: '/', label: 'Concept Playground' },
  { href: '/blog', label: 'Markdown Content' },
  { href: '/api/time.json', label: 'Time Endpoint' },
  { href: '/rendering', label: 'SSG/SSR Guide' }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <Header siteTitle={pageTitle} tagline="Performance-focused websites with Astro" navItems={navItems} />

      <main class="page-main">
        <section class="content-card">
          <slot />
        </section>
      </main>

      <Footer author="Dedi Kusniadi learning adaptation" links={footerLinks} />
    </div>

    <script>
      import '../scripts/menu.js';
    </script>
  </body>
</html>
